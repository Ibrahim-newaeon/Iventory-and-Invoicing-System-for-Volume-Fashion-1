# ===========================================
# Volume Fashion - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values

# ---------- Required ----------

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/volume_fashion

# Session secret (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
SESSION_SECRET=

# ---------- Application ----------

# Application URL (used for QR codes, PDF links, etc.)
APP_URL=http://localhost:5000

# Server port (default: 5000)
PORT=5000

# Node environment (development | production)
NODE_ENV=development

# CORS allowed origins (comma-separated, default: APP_URL)
CORS_ORIGINS=http://localhost:5000

# ---------- Email (Optional) ----------

# Gmail SMTP credentials for sending invoices and password reset emails
EMAIL_USER=
EMAIL_PASS=

# ---------- WhatsApp / Twilio (Optional) ----------

# Twilio credentials for WhatsApp invoice delivery
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ---------- Storage (Optional) ----------

# Storage provider: local (default) | s3 | gcs
STORAGE_PROVIDER=local

# Local storage directory (default: ./uploads)
UPLOAD_DIR=./uploads

# AWS S3 settings (if STORAGE_PROVIDER=s3)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=
# AWS_S3_BUCKET=

# Google Cloud Storage settings (if STORAGE_PROVIDER=gcs)
# GCS_BUCKET=
# GCS_PROJECT_ID=
